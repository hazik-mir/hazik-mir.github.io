<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
  <title>Hazik QR • generator</title>
  <!-- Open Sans & QRCode.js -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.1/build/qrcode.min.js"></script>
  <style>
    :root {
      --black: #000000;
      --white: #ffffff;
      --gray-mid: #8a8a8a;
      --border-width: 3px;
    }
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    html {
      scroll-behavior: smooth;
    }
    body {
      background: var(--white);
      color: var(--black);
      font-family: 'Open Sans', sans-serif;
      font-weight: 400;
      line-height: 1.55;
      overflow-x: hidden;
    }
    a {
      color: inherit;
      text-decoration: none;
    }
    ul {
      list-style: none;
    }
    ::selection {
      background: var(--black);
      color: var(--white);
    }
    :focus-visible {
      outline: 3px solid var(--black);
      outline-offset: 3px;
    }

    /* header identical to hazik.in */
    header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 60;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px clamp(20px, 5vw, 56px);
      background: var(--black);
      color: var(--white);
      border-bottom: 3px solid var(--black);
      animation: slideDown .6s ease;
    }
    .logo {
      font-size: 1.25rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      text-transform: uppercase;
      display: flex;
      align-items: center;
      gap: 2px;
    }
    .logo .dot {
      width: 7px;
      height: 7px;
      background: var(--white);
      border-radius: 50%;
      display: inline-block;
      margin: 0 4px;
      animation: pulse 2s ease-in-out infinite;
    }
    nav ul {
      display: flex;
      gap: clamp(18px, 3vw, 36px);
      align-items: center;
    }
    nav a {
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--white);
      position: relative;
      padding: 6px 0;
      transition: all .3s ease;
    }
    nav a:not(.nav-cta)::after {
      content: '';
      position: absolute;
      left: 0;
      bottom: 0;
      width: 0;
      height: 2px;
      background: var(--white);
      transition: width .25s ease;
    }
    nav a:not(.nav-cta):hover::after {
      width: 100%;
    }
    nav a:hover {
      transform: translateY(-2px);
    }
    .nav-cta {
      padding: 9px 18px !important;
      border: 2px solid var(--white);
      transition: background .2s ease, color .2s ease, transform .2s ease;
    }
    .nav-cta:hover {
      background: var(--white);
      color: var(--black);
      transform: translateY(-3px);
    }

    /* main content */
    .page {
      padding-top: 100px;
      min-height: 100vh;
      background: var(--white);
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 24px 60px;
    }

    /* section headings */
    .section-head {
      margin-bottom: 40px;
      animation: riseIn .8s ease forwards;
    }
    .section-head .index-no {
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: .2em;
      margin-bottom: 12px;
      display: block;
      color: var(--gray-mid);
    }
    .section-head h2 {
      font-weight: 800;
      text-transform: uppercase;
      font-size: clamp(2rem, 5vw, 2.8rem);
      line-height: 1.1;
    }

    .grid-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
      align-items: start;
    }

    @media (max-width: 860px) {
      .grid-layout {
        grid-template-columns: 1fr;
        gap: 32px;
      }
    }

    /* card style – heavy borders, black/white contrast */
    .card {
      background: var(--white);
      border: 3px solid var(--black);
      padding: clamp(24px, 4vw, 34px);
      box-shadow: 4px 4px 0 rgba(0,0,0,0.1);
      transition: all 0.25s ease;
    }
    .card:hover {
      box-shadow: 8px 8px 0 rgba(0,0,0,0.15);
      transform: translateY(-4px);
    }
    .card h3 {
      font-weight: 800;
      text-transform: uppercase;
      font-size: 1.3rem;
      margin-bottom: 16px;
      letter-spacing: -0.3px;
    }

    textarea, input[type="text"] {
      width: 100%;
      border: 2px solid var(--black);
      padding: 14px;
      font-family: 'Open Sans', sans-serif;
      font-size: 0.95rem;
      background: var(--white);
      color: var(--black);
      resize: vertical;
      margin-bottom: 16px;
      font-weight: 500;
    }
    textarea:focus, input:focus {
      outline: 3px solid var(--black);
    }

    .btn {
      font-weight: 800;
      font-size: 0.9rem;
      letter-spacing: .04em;
      text-transform: uppercase;
      padding: 14px 24px;
      border: 3px solid var(--black);
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: var(--black);
      color: var(--white);
      transition: 0.2s ease;
      box-shadow: 0 4px 0 rgba(0,0,0,0.2);
      width: 100%;
      margin-top: 8px;
    }
    .btn:hover {
      background: var(--white);
      color: var(--black);
      transform: translateY(-3px);
      box-shadow: 0 6px 0 rgba(0,0,0,0.2);
    }
    .btn-ghost {
      background: var(--white);
      color: var(--black);
    }
    .btn-ghost:hover {
      background: var(--black);
      color: var(--white);
    }

    .qr-preview {
      background: var(--white);
      border: 3px solid var(--black);
      padding: 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 280px;
      position: relative;
      box-shadow: 4px 4px 0 rgba(0,0,0,0.1);
      margin-bottom: 20px;
    }
    #qrCanvasContainer {
      position: relative;
      display: inline-block;
      line-height: 0;
      background: #fff;
    }
    canvas {
      display: block;
      width: 100%;
      height: auto;
      max-width: 260px;
      border: 2px solid #eee;
    }

    .watermark-badge {
      position: absolute;
      font-weight: 700;
      font-size: 11px;
      background: rgba(0,0,0,0.7);
      color: white;
      padding: 2px 8px;
      letter-spacing: 0.5px;
      border-radius: 2px;
      pointer-events: none;
      white-space: nowrap;
      backdrop-filter: blur(2px);
      transition: all 0.2s;
      z-index: 10;
    }

    .controls-row {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 12px;
    }

    .badge-group {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin: 16px 0 8px;
    }
    .badge {
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: 6px 14px;
      border: 2px solid var(--black);
      background: white;
      cursor: pointer;
      transition: 0.2s;
      box-shadow: 2px 2px 0 rgba(0,0,0,0.1);
    }
    .badge.active {
      background: var(--black);
      color: var(--white);
      border-color: var(--black);
    }
    .badge:hover {
      transform: translateY(-2px);
      box-shadow: 3px 3px 0 rgba(0,0,0,0.2);
    }

    .color-input-wrap {
      display: flex;
      align-items: center;
      gap: 10px;
      margin: 8px 0;
    }
    input[type="color"] {
      width: 40px;
      height: 40px;
      border: 2px solid var(--black);
      background: white;
      cursor: pointer;
    }

    .file-upload {
      margin: 10px 0;
    }
    .file-upload label {
      font-weight: 700;
      font-size: 0.8rem;
      text-transform: uppercase;
      display: block;
      margin-bottom: 4px;
    }

    .text-input-group {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    footer {
      background: var(--black);
      color: var(--white);
      padding: 30px 20px;
      text-align: center;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      border-top: 3px solid var(--black);
      margin-top: 40px;
    }

    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-30px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes riseIn {
      from { opacity: 0; transform: translateY(18px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes pulse {
      0%,100% { opacity: 1; } 50% { opacity: 0.5; }
    }
  </style>
</head>
<body>
  <header>
    <div class="logo">hazik<span class="dot"></span>qr</div>
    <nav>
      <ul>
        <li><a href="#">QR Gen</a></li>
        <li><a href="#" class="nav-cta">[H]</a></li>
      </ul>
    </nav>
  </header>

  <main class="page">
    <div class="container">
      <div class="section-head">
        <span class="index-no">QR · generator</span>
        <h2>Create & style your QR</h2>
      </div>

      <div class="grid-layout">
        <!-- LEFT: inputs -->
        <div>
          <div class="card">
            <h3>📱 content</h3>
            <textarea id="qrText" placeholder="Enter text or URL..." rows="3">https://hazik.in</textarea>
            <button id="generateBtn" class="btn">✨ Generate QR</button>
          </div>

          <div class="card" style="margin-top: 24px;">
            <h3>🎨 background & style</h3>
            <div class="color-input-wrap">
              <span style="font-weight:700;">BG color:</span>
              <input type="color" id="bgColor" value="#ffffff">
              <span style="font-weight:700; margin-left:12px;">QR dark:</span>
              <input type="color" id="darkColor" value="#000000">
            </div>

            <div class="file-upload">
              <label>🖼️ Add image (logo/sticker)</label>
              <input type="file" id="imageUpload" accept="image/*" style="font-size:0.85rem;">
              <button id="removeImageBtn" class="btn btn-ghost" style="padding:8px; margin-top:6px;">Remove image</button>
            </div>

            <div style="margin-top:14px;">
              <label style="font-weight:700; font-size:0.8rem;">🔤 Add stylish text</label>
              <div class="text-input-group">
                <input type="text" id="overlayText" placeholder="e.g. HAZIK" maxlength="15" style="margin-bottom:0;">
                <button id="applyTextBtn" class="btn" style="width:auto; padding:10px 18px;">Apply</button>
              </div>
              <button id="clearTextBtn" class="btn btn-ghost" style="padding:8px; margin-top:6px;">Clear text</button>
            </div>
          </div>
        </div>

        <!-- RIGHT: preview + watermark cards -->
        <div>
          <div class="qr-preview" id="qrPreview">
            <div id="qrCanvasContainer">
              <canvas id="qrCanvas"></canvas>
            </div>
            <p style="margin-top:10px; font-weight:600; font-size:0.9rem;" id="previewHint">QR preview</p>
          </div>

          <div class="card" style="margin-top:16px;">
            <h3>🔖 watermark [H] hazik.in</h3>
            <div class="badge-group" id="watermarkGroup">
              <span class="badge active" data-pos="bottom-left">Bottom left</span>
              <span class="badge" data-pos="top-left">Top Left</span>
              <span class="badge" data-pos="top-right">Top Right</span>
              <span class="badge" data-pos="middle">Middle</span>
              <span class="badge" data-pos="bottom-right">Bottom right</span>
              <span class="badge" data-pos="off">Off</span>
            </div>
            <p style="font-size:0.8rem; color:var(--gray-mid);">Watermark adjusts live on QR</p>
            <button id="downloadBtn" class="btn" style="margin-top:12px;">⬇️ Download QR</button>
          </div>
        </div>
      </div>
    </div>
  </main>

  <footer>
    hazik.in — qr toolkit · watermark included
  </footer>

  <script>
    (function() {
      // DOM elements
      const qrText = document.getElementById('qrText');
      const generateBtn = document.getElementById('generateBtn');
      const canvas = document.getElementById('qrCanvas');
      const container = document.getElementById('qrCanvasContainer');
      const bgColorInput = document.getElementById('bgColor');
      const darkColorInput = document.getElementById('darkColor');
      const imageUpload = document.getElementById('imageUpload');
      const removeImageBtn = document.getElementById('removeImageBtn');
      const overlayText = document.getElementById('overlayText');
      const applyTextBtn = document.getElementById('applyTextBtn');
      const clearTextBtn = document.getElementById('clearTextBtn');
      const downloadBtn = document.getElementById('downloadBtn');
      const watermarkBadges = document.querySelectorAll('#watermarkGroup .badge');
      
      let currentQRData = 'https://hazik.in';
      let uploadedImage = null;        // HTMLImageElement or null
      let overlayTextValue = '';
      let watermarkPosition = 'bottom-left'; // default

      // Create watermark element dynamically
      const watermarkEl = document.createElement('div');
      watermarkEl.className = 'watermark-badge';
      watermarkEl.textContent = '[H] hazik.in';
      watermarkEl.style.display = 'flex';
      container.appendChild(watermarkEl);

      function updateWatermarkPosition(pos) {
        if (!watermarkEl) return;
        watermarkEl.style.position = 'absolute';
        const offset = '8px';
        
        switch(pos) {
          case 'top-left':
            watermarkEl.style.top = offset;
            watermarkEl.style.left = offset;
            watermarkEl.style.bottom = 'auto';
            watermarkEl.style.right = 'auto';
            watermarkEl.style.display = 'flex';
            break;
          case 'top-right':
            watermarkEl.style.top = offset;
            watermarkEl.style.right = offset;
            watermarkEl.style.bottom = 'auto';
            watermarkEl.style.left = 'auto';
            watermarkEl.style.display = 'flex';
            break;
          case 'middle':
            watermarkEl.style.top = '50%';
            watermarkEl.style.left = '50%';
            watermarkEl.style.transform = 'translate(-50%, -50%)';
            watermarkEl.style.bottom = 'auto';
            watermarkEl.style.right = 'auto';
            watermarkEl.style.display = 'flex';
            break;
          case 'bottom-right':
            watermarkEl.style.bottom = offset;
            watermarkEl.style.right = offset;
            watermarkEl.style.top = 'auto';
            watermarkEl.style.left = 'auto';
            watermarkEl.style.display = 'flex';
            break;
          case 'bottom-left':
          default:
            watermarkEl.style.bottom = offset;
            watermarkEl.style.left = offset;
            watermarkEl.style.top = 'auto';
            watermarkEl.style.right = 'auto';
            watermarkEl.style.display = 'flex';
            break;
          case 'off':
            watermarkEl.style.display = 'none';
            break;
        }
        if (pos !== 'middle') {
          watermarkEl.style.transform = 'none';
        }
      }

      // Badge click handler
      watermarkBadges.forEach(badge => {
        badge.addEventListener('click', function(e) {
          watermarkBadges.forEach(b => b.classList.remove('active'));
          this.classList.add('active');
          const pos = this.getAttribute('data-pos');
          watermarkPosition = pos;
          updateWatermarkPosition(pos);
          // re-render QR with current settings to apply watermark visually on canvas? 
          // Watermark is HTML overlay, canvas download handled separately.
          drawQRWithOverlay();
        });
      });

      // Initialize watermark position
      updateWatermarkPosition('bottom-left');

      // Generate QR code on canvas (base QR without extra drawings)
      function generateBaseQR(text) {
        return new Promise((resolve, reject) => {
          if (!text.trim()) {
            text = 'https://hazik.in';
          }
          const bgColor = bgColorInput.value || '#ffffff';
          const darkColor = darkColorInput.value || '#000000';
          
          QRCode.toCanvas(canvas, text, {
            width: 300,
            margin: 2,
            color: {
              dark: darkColor,
              light: bgColor
            },
            errorCorrectionLevel: 'H'
          }, (error) => {
            if (error) {
              console.error(error);
              reject(error);
            } else {
              currentQRData = text;
              resolve();
            }
          });
        });
      }

      // Draw image and text overlay on canvas after QR is generated
      function drawOverlaysOnCanvas() {
        if (!canvas || !currentQRData) return;
        
        const ctx = canvas.getContext('2d');
        // We need to re-generate QR first to have clean base, then draw image/text.
        // Better approach: re-generate QR and in callback draw additions.
        const bg = bgColorInput.value;
        const dark = darkColorInput.value;
        
        QRCode.toCanvas(canvas, currentQRData, {
          width: 300,
          margin: 2,
          color: { dark: dark, light: bg },
          errorCorrectionLevel: 'H'
        }, (error) => {
          if (error) return;
          
          const ctx2 = canvas.getContext('2d');
          const w = canvas.width;
          const h = canvas.height;
          
          // Draw uploaded image if exists
          if (uploadedImage && uploadedImage.complete) {
            const imgSize = w * 0.22; // ~22% of QR size
            const x = (w - imgSize) / 2;
            const y = (h - imgSize) / 2;
            ctx2.save();
            // white background behind logo for readability
            ctx2.fillStyle = '#ffffff';
            ctx2.fillRect(x-4, y-4, imgSize+8, imgSize+8);
            ctx2.drawImage(uploadedImage, x, y, imgSize, imgSize);
            ctx2.restore();
          }
          
          // Draw overlay text
          if (overlayTextValue.trim()) {
            ctx2.save();
            const fontSize = w * 0.09;
            ctx2.font = `800 ${fontSize}px 'Open Sans', sans-serif`;
            ctx2.textAlign = 'center';
            const textWidth = ctx2.measureText(overlayTextValue).width;
            const textHeight = fontSize;
            
            // background pill
            const padX = 14;
            const padY = 8;
            ctx2.fillStyle = '#000000';
            ctx2.beginPath();
            ctx2.roundRect(
              (w/2) - textWidth/2 - padX,
              (h/2) - textHeight/2 - padY + (uploadedImage ? 40 : 0),
              textWidth + padX*2,
              textHeight + padY*2,
              8
            );
            ctx2.fill();
            ctx2.fillStyle = '#ffffff';
            ctx2.fillText(overlayTextValue, w/2, h/2 + textHeight/3 + (uploadedImage ? 40 : 0));
            ctx2.restore();
          }
        });
      }

      // helper for roundRect
      CanvasRenderingContext2D.prototype.roundRect = function (x, y, w, h, r) {
        if (w < 2 * r) r = w / 2;
        if (h < 2 * r) r = h / 2;
        this.moveTo(x + r, y);
        this.lineTo(x + w - r, y);
        this.quadraticCurveTo(x + w, y, x + w, y + r);
        this.lineTo(x + w, y + h - r);
        this.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
        this.lineTo(x + r, y + h);
        this.quadraticCurveTo(x, y + h, x, y + h - r);
        this.lineTo(x, y + r);
        this.quadraticCurveTo(x, y, x + r, y);
        this.closePath();
        return this;
      };

      async function drawQRWithOverlay() {
        if (!currentQRData) return;
        await generateBaseQR(currentQRData);
        drawOverlaysOnCanvas();
      }

      // Event Listeners
      generateBtn.addEventListener('click', async () => {
        const text = qrText.value.trim();
        if (!text) {
          alert('Please enter some content for QR code.');
          return;
        }
        currentQRData = text;
        await drawQRWithOverlay();
      });

      bgColorInput.addEventListener('input', async () => {
        if (currentQRData) await drawQRWithOverlay();
      });
      darkColorInput.addEventListener('input', async () => {
        if (currentQRData) await drawQRWithOverlay();
      });

      // Image upload
      imageUpload.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = (ev) => {
          const img = new Image();
          img.crossOrigin = 'Anonymous';
          img.onload = () => {
            uploadedImage = img;
            drawQRWithOverlay();
          };
          img.src = ev.target.result;
        };
        reader.readAsDataURL(file);
      });

      removeImageBtn.addEventListener('click', () => {
        uploadedImage = null;
        imageUpload.value = '';
        drawQRWithOverlay();
      });

      applyTextBtn.addEventListener('click', () => {
        overlayTextValue = overlayText.value.trim();
        drawQRWithOverlay();
      });

      clearTextBtn.addEventListener('click', () => {
        overlayTextValue = '';
        overlayText.value = '';
        drawQRWithOverlay();
      });

      // Download QR with watermark included (composite canvas)
      downloadBtn.addEventListener('click', () => {
        if (!currentQRData) {
          alert('Generate a QR first.');
          return;
        }
        
        // Create an offscreen canvas combining QR + watermark
        const offCanvas = document.createElement('canvas');
        const size = 600;
        offCanvas.width = size;
        offCanvas.height = size;
        const ctx = offCanvas.getContext('2d');
        
        // Draw current QR canvas scaled
        ctx.drawImage(canvas, 0, 0, size, size);
        
        // Draw watermark unless off
        if (watermarkPosition !== 'off') {
          ctx.save();
          ctx.font = 'bold 28px "Open Sans", sans-serif';
          ctx.fillStyle = 'rgba(0,0,0,0.75)';
          const text = '[H] hazik.in';
          const metrics = ctx.measureText(text);
          const textWidth = metrics.width;
          const textHeight = 32;
          const padding = 12;
          
          let x = 16, y = size - 40;
          if (watermarkPosition === 'top-left') { x = 16; y = 40; }
          else if (watermarkPosition === 'top-right') { x = size - textWidth - 30; y = 40; }
          else if (watermarkPosition === 'middle') { x = (size - textWidth)/2; y = size/2; }
          else if (watermarkPosition === 'bottom-right') { x = size - textWidth - 30; y = size - 40; }
          else if (watermarkPosition === 'bottom-left') { x = 16; y = size - 40; }
          
          ctx.fillStyle = '#000000';
          ctx.fillRect(x-6, y - textHeight + 6, textWidth + 18, textHeight + 10);
          ctx.fillStyle = '#ffffff';
          ctx.fillText(text, x, y);
          ctx.restore();
        }
        
        const link = document.createElement('a');
        link.download = `hazik-qr-${Date.now()}.png`;
        link.href = offCanvas.toDataURL('image/png');
        link.click();
      });

      // Initial QR generation
      window.addEventListener('load', () => {
        currentQRData = qrText.value.trim() || 'https://hazik.in';
        drawQRWithOverlay();
      });

    })();
  </script>
</body>
</html>
